 const response = await GoogleSignin.signIn();\n\n      if (response.type === \"cancelled\") {\n        return { type: \"cancel\" };\n      }\n\n      const { user: googleUser } = response.data!;\n      const user = {\n        id: googleUser.id,\n        email: googleUser.email,\n        name: googleUser.name ?? \"\",\n        picture: googleUser.photo ?? undefined,\n        given_name: googleUser.givenName ?? undefined,\n        family_name: googleUser.familyName ?? undefined,\n      };\n\n      setUserInfo(user);\n\n      const result: GoogleAuthResult = {\n        type: \"success\",\n        user,\n        idToken: response.data?.idToken ?? undefined,\n      };\n\n      propsRef.current?.onSuccess?.(result);\n      return result;\n    } catch (error) {\n      if (isErrorWithCode(error)) {\n        if (error.code === statusCodes.SIGN_IN_CANCELLED) {\n          return { type: \"cancel\" };\n        }\n        if (error.code === statusCodes.IN_PROGRESS) {\n          return { type: \"cancel\" };\n        }\n      }\n\n      const errorMessage =\n        error instanceof Error ? error.message : \"Google sign-in failed\";\n      propsRef.current?.onError?.(errorMessage);\n      return { type: \"error\", error: errorMessage };\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  const signOut = useCallback(async () => {\n    try {\n      await GoogleSignin.signOut();\n    } catch {\n      // silent\n    }\n    setUserInfo(null);\n  }, []);\n\n  return {\n    signInAsync,\n    signOut,\n    userInfo,\n    loading,\n    isReady: true, // native SDK is always ready after configure\n  };\n};\n\nexport default useGoogleAuth;\n```\n\nKey differences from old implementation:\n- No `expo-auth-session`, no `expo-web-browser` imports\n- `GoogleSignin.configure()` called on mount\n- `signInAsync()` uses native `GoogleSignin.signIn()` — shows native account picker, no browser redirect\n- Cancellation is detected via `statusCodes.SIGN_IN_CANCELLED` instead of `response.type`\n- `isReady` is always `true` (native SDK doesn't have the \"request not ready\" state)\n- `onSuccess`/`onError` callbacks still fire the same way\n\n- [ ] **Step 2: Verify no other files import from `expo-auth-session/providers/google`**\n\nRun:\n```bash\ncd /Users/abhik.ray/Kindred/frontend && grep -r \"expo-auth-session/providers/google\" --include=\"*.tsx\" --include=\"*.ts\" .\n```\n\nExpected: No results (only `useGoogleAuth.tsx` used it, and it's been rewritten).\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add frontend/hooks/useGoogleAuth.tsx\ngit commit -m \"feat: rewrite useGoogleAuth with native @react-native-google-signin SDK\"\n```\n\n---\n\n### Task 3: Fix Google button styling in OnboardModal\n\n**Files:**\n- Modify: `frontend/components/modals/OnboardModal.tsx:470-471`\n\n- [ ] **Step 1: Remove dimmed opacity from Google button**\n\nIn `OnboardModal.tsx`, in the `useStyles` function, change the `googleButton` style. Remove line 471:\n\n```typescript\n// Before:\n            position: \"relative\",\n            opacity: 0.7, // Slightly dimmed to indicate unavailable\n\n// After:\n            position: \"relative\",\n```\n\n- [ ] **Step 2: Commit**\n\n```bash\ngit add frontend/components/modals/OnboardModal.tsx\ngit commit -m \"fix: remove dimmed opacity from Google sign-in button\"\n```\n\n---\n\n### Task 4: Add auth error constants to `errorParser.ts`\n\n**Files:**\n- Modify: `frontend/utils/errorParser.ts:163-187`\n\n- [ ] **Step 1: Extend `ERROR_MESSAGES` with auth-specific constants**\n\nIn `frontend/utils/errorParser.ts`, replace the `ERROR_MESSAGES` object with:\n\n```typescript\nexport const ERROR_MESSAGES = {\n    // Network\n    NETWORK_ERROR: \"Unable to connect. Please check your internet connection.\",\n    TIMEOUT: \"Request timed out. Please try again.\",\n\n    // Authentication - Google\n    GOOGLE_AUTH_FAILED: \"Google sign-in failed. Please try again.\",\n\n    // Authentication - Apple\n    APPLE_AUTH_FAILED: \"Apple sign-in f