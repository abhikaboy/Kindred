# Backend base URL (client appends "/api"). Leave EMPTY in web dev to use the
# Vite proxy in vite.config.ts. Set to an absolute URL for Tauri/prod builds.
VITE_API_URL=

# --- OAuth ---
# Google web client ID (GIS). Defaults to the mobile web client if unset; must be
# in the backend's GOOGLE_CLIENT_IDS, with localhost:1420 + prod origin as authorized origins.
VITE_GOOGLE_CLIENT_ID=
# Apple Sign in Services ID (web/desktop). When set, the "Continue with Apple"
# button appears. Backend must set APPLE_SERVICE_ID to the same value.
VITE_APPLE_SERVICE_ID=

# --- Media ---
# Tenor v2 API key for the kudos GIF picker. Same value as mobile's
# EXPO_PUBLIC_TENOR_API_KEY. Without it, GIF search shows an "unavailable" note.
VITE_TENOR_API_KEY=
